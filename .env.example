# VIGISCAM AI worker configuration (all optional; sensible CPU defaults).
VIGISCAM_AI_HOST=0.0.0.0
VIGISCAM_AI_PORT=8000
VIGISCAM_AI_LOG_LEVEL=info

# Shared embedding backbone (powers embeddings + semantic NLP + insights).
VIGISCAM_AI_EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2
VIGISCAM_AI_DEVICE=cpu            # set to "cuda" on a GPU node
VIGISCAM_AI_WARM_ON_STARTUP=true

# Heavy authenticity tier (optional — leave unset to return INCONCLUSIVE).
# VIGISCAM_AI_DEEPFAKE_IMAGE_MODEL=dima806/deepfake_vs_real_image_detection
# VIGISCAM_AI_VOICE_SPOOF_MODEL=<an anti-spoofing model id>
